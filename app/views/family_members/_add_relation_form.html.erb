<%
  toggle_id = "add-relation-toggle-#{member.id}"
  relation_options = [
    [ "mother", "Мама" ],
    [ "father", "Папа" ],
    [ "spouse", "Супруг(а)" ],
    [ "child", "Ребёнок" ],
    [ "sibling", "Брат/сестра" ]
  ]
%>

<input type="checkbox" id="<%= toggle_id %>" class="AddRelationToggle">
<label for="<%= toggle_id %>" class="AddRelationButton" aria-label="Добавить родственника к <%= member.name %>">+</label>

<div class="AddRelationOverlay">
  <div class="AddRelationModal">
    <label for="<%= toggle_id %>" class="EditProfileClose">
      <span></span>
      <span></span>
    </label>

    <h3 class="AddRelationTitle">Добавить родственника для «<%= member.name %>»</h3>

    <%= form_with url: add_relation_family_member_path(member), method: :post, class: "MemoryForm" do %>
      <div class="MemoryFormField">
        <span class="MemoryFormLabel">Кем приходится</span>
        <div class="MemoryFormTags">
          <% relation_options.each_with_index do |(value, label), index| %>
            <label class="tag MemoryFormTag">
              <input type="radio" name="relation_type" value="<%= value %>" <%= "checked" if index.zero? %> required>
              <%= label %>
            </label>
          <% end %>
        </div>
      </div>

      <div class="MemoryFormField">
        <label class="MemoryFormLabel">Выберите члена семьи</label>
        <select name="existing_member_id" class="MemoryFormSelect">
          <option value="" selected disabled>Выбрать члена семьи</option>
          <% current_user.family.family_members.where.not(id: member.id).order(:name).each do |candidate| %>
            <option value="<%= candidate.id %>"><%= candidate.name %></option>
          <% end %>
        </select>
        <p class="MemoryFormHint">Проверьте имя — выбор человека, уже зарегистрированного в Aeterna, сразу меняет дерево для всей семьи.</p>
      </div>

      <div class="AddRelationExistingGender MemoryFormField">
        <span class="MemoryFormLabel">Пол</span>
        <div class="MemoryFormTags">
          <label class="tag MemoryFormTag">
            <input type="radio" name="gender" value="f" checked>
            Женский
          </label>
          <label class="tag MemoryFormTag">
            <input type="radio" name="gender" value="m">
            Мужской
          </label>
        </div>
      </div>

      <label class="AddRelationCreateNewToggle">
        <input type="checkbox" name="create_new_person" value="1" class="AddRelationCreateNewCheck">
        Создать нового
      </label>

      <div class="AddRelationNewPersonFields">
        <div class="MemoryFormField">
          <label class="MemoryFormLabel">Имя нового человека</label>
          <input type="text" name="name" class="MemoryFormInput" placeholder="Имя и фамилия">
        </div>

        <div class="MemoryFormField">
          <span class="MemoryFormLabel">Годы жизни</span>
          <div class="AddRelationLifeYears">
            <input type="date" name="birth_date" class="MemoryFormInput" placeholder="Дата рождения">
            <input type="date" name="death_date" class="MemoryFormInput" placeholder="Дата смерти (если есть)">
          </div>
        </div>

      </div>

      <%= submit_tag "Добавить", class: "MemoryFormSubmit" %>
    <% end %>
  </div>
</div>
