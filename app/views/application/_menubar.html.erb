<nav class="S_MenuBar">
    <div>
        <%= link_to user_signed_in? ? home_path : root_path, class: "Logo" do %>
            <%= image_tag "icons/Logo.svg", class: "LogoImage" %>
        <% end %>
        <div class="Pages">

        <% if user_signed_in? && current_user.admin? %>

            <%= link_to admin_timeline_path, class: "PageLink" do %>
            Лента времени
            <%= image_tag "icons/RightIconArrow.svg", class: "RightIconArrow" %>
            <% end %>

            <%= link_to admin_family_tree_path, class: "PageLink" do %>
            Семейное древо
            <%= image_tag "icons/RightIconArrow.svg", class: "RightIconArrow" %>
            <% end %>

            <%= link_to admin_family_members_path, class: "PageLink" do %>
            Члены семьи
            <%= image_tag "icons/RightIconArrow.svg", class: "RightIconArrow" %>
            <% end %>

            <%= link_to admin_subscriptions_path, class: "PageLink" do %>
            Подписки
            <%= image_tag "icons/RightIconArrow.svg", class: "RightIconArrow" %>
            <% end %>

            <% elsif user_signed_in? %>
                <%= link_to timeline_path, class: "PageLink" do %>
                Лента времени
                <% end %>

                <%= link_to family_tree_path, class: "PageLink" do %>
                Семейное древо
                <% end %>
        <% end %>

        <% if user_signed_in? %>
          <%= link_to pages_about_path, class: "PageLinkPublic" do %>
              О нас
          <% end %>
        <% end %>

        </div>
    </div>

    <div>
        <% if user_signed_in? %>
            <%#= link_to current_user.email, edit_user_registration_path %>
            <%#= link_to "Мои воспоминания", my_memories_path %>
            <div class="AddMemoryMenu">
                <span class="AddMemoryButton">
                    Добавить
                    <span class="PlusIcon"></span>
                </span>
                <div class="AddMemoryDropdown">
                    <%= link_to "Воспоминание", new_memory_path, class: "MoreMenuItem" %>
                    <%= link_to "Подборку", new_collection_path, class: "MoreMenuItem" %>
                </div>
            </div>

            <%= link_to my_profile_path, class: "ProfileButton" do %>
                <% profile = current_user.profile %>
                <% if profile&.avatar&.attached? %>
                    <%= image_tag profile.avatar, class: "ProfileImageButton" %>
                <% else %>
                    <%
                      avatar_colors = %w[#6795d6 #e19593 #f2de97 #6d8e6a #a3b7a1 #ffb4b2]
                      name_str = profile&.name.to_s
                      color = avatar_colors[name_str.sum % avatar_colors.length]
                      initials = name_str.split.first(2).map { |w| w[0]&.upcase }.join
                    %>
                    <div class="ProfilePlaceholder ProfilePlaceholderButton" style="background-color: <%= color %>;">
                      <span class="ProfileInitials"><%= initials.presence || "?" %></span>
                    </div>
                <% end %>
            <% end %>
            <%#= link_to "Выйти", destroy_user_session_path, data: {"turbo_method": :delete } %>
        <% else %>
            <%= link_to "Войти", new_user_session_path, class: "SignInButton" %>
            <%#= link_to "Зарегистрироваться", new_user_registration_path %>
        <% end %>
    </div>

    <input type="checkbox" id="mobile-menu-toggle" class="MobileMenuToggle">

    <div class="MobileTopBar">
        <%= link_to user_signed_in? ? home_path : root_path, class: "Logo" do %>
            <%= image_tag "icons/Logo.svg", class: "LogoImage" %>
        <% end %>
        <label for="mobile-menu-toggle" class="BurgerButton">
            <span></span>
            <span></span>
            <span></span>
        </label>
    </div>

    <div class="MobileMenuOverlay">
        <div class="MobileMenuHead">
            <%= link_to user_signed_in? ? home_path : root_path, class: "Logo" do %>
                <%= image_tag "icons/Logo.svg", class: "LogoImage" %>
            <% end %>
            <label for="mobile-menu-toggle" class="MobileMenuClose">
                <span></span>
                <span></span>
            </label>
        </div>

        <div class="MobileMenuLinks">
            <% if user_signed_in? && current_user.admin? %>
                <%= link_to "Лента времени", admin_timeline_path, class: "MobileMenuLink" %>
                <%= link_to "Семейное древо", admin_family_tree_path, class: "MobileMenuLink" %>
                <%= link_to "Члены семьи", admin_family_members_path, class: "MobileMenuLink" %>
                <%= link_to "Подписки", admin_subscriptions_path, class: "MobileMenuLink" %>
            <% elsif user_signed_in? %>
                <%= link_to "Лента времени", timeline_path, class: "MobileMenuLink" %>
                <%= link_to "Семейное древо", family_tree_path, class: "MobileMenuLink" %>
            <% end %>

            <%= link_to "О нас", pages_about_path, class: "MobileMenuLink" %>

            <% if user_signed_in? %>
                <%= link_to "Профиль", my_profile_path, class: "MobileMenuLink" %>
            <% end %>
        </div>

        <div class="MobileMenuActions">
            <% if user_signed_in? %>
                <input type="checkbox" id="mobile-add-toggle" class="MobileAddToggle">
                <label for="mobile-add-toggle" class="AddMemoryButton MobileAddButton">
                    Добавить
                    <span class="PlusIcon"></span>
                </label>
                <div class="MobileAddOptions">
                    <%= link_to "Воспоминание", new_memory_path, class: "MobileAddOption" %>
                    <%= link_to "Подборку", new_collection_path, class: "MobileAddOption" %>
                </div>
            <% else %>
                <%= link_to "Войти", new_user_session_path, class: "SignInButton" %>
            <% end %>
        </div>
    </div>
</nav>

<script>
  document.addEventListener("turbo:before-cache", function () {
    var menuToggle = document.getElementById("mobile-menu-toggle");
    if (menuToggle) menuToggle.checked = false;

    var addToggle = document.getElementById("mobile-add-toggle");
    if (addToggle) addToggle.checked = false;
  });
</script>
