<section class="Cover" data-controller="parallax">
    <div class="CoverInner">
        <div class="CoverText">
            <div class="Heading Home">
                <h1>СОБЕРИТЕ ИСТОРИЮ ВАШЕЙ СЕМЬИ</h1>
                <p>Соберите фотографии, истории и важные моменты в одном месте — вместе с близкими</p>
            </div>
            <div class="CTA">
            <%= link_to root_url do %>
                Добавить воспоминание
                <span class="ArrowBox"></span>
            <% end %>
            </div>
        </div>
        <div class="CoverMemories Home">
            <div class="TextMemory" id="TextMemory4" data-parallax-target="layer" data-parallax-speed="0.32">2020. Папа научился делать видеозвонки — теперь звонит каждое утро</div>
            <%= image_tag 'home/GrannyImg.svg', class: 'GrannyImg', data: { parallax_target: 'layer', parallax_speed: '0.45' } %>
            <%= image_tag 'home/CrochetImg.svg', class: 'CrochetImg', data: { parallax_target: 'layer', parallax_speed: '0.6' } %>
            <%= image_tag 'about/ImportantMoments2.webp', class: 'ImportantMoments2', data: { parallax_target: 'layer', parallax_speed: '0.4' } %>
            <%= image_tag 'home/BirdImg.svg', class: 'BirdImg', data: { parallax_target: 'layer', parallax_speed: '-0.4' } %>
            <%= image_tag 'about/whatDoesAeternaDo.webp', class: 'whatDoesAeternaDo', data: { parallax_target: 'layer', parallax_speed: '-0.3' } %>
        </div>
    </div>
</section>

<section class="RecentNotes">
  <div class="PageWrapper">
    <div class="RecentNotesHeading">
      <p class="Subtitle">Недавние записи</p>
      <h2>ЧТО ДОБАВИЛИ БЛИЗКИЕ</h2>
      <p class="Description">Загружайте снимки, записывайте истории и делитесь ими с близкими</p>
      <div class="RecentNotesImagesWrapper">
        <div class="RecentNotesImages" id="recentNotesSlider">
        <% @recent_memories.each do |memory| %>
          <%= link_to memory_path(memory), class: 'ImageContainer' do %>
            <% if memory.image.present? %>
              <%= image_tag memory.image.preview.url %>
            <% else %>
              <div class="RecentNoteText">
                <%= truncate(memory.body, length: 120) %>
              </div>
            <% end %>
            <div class="tags">
              <% tag_colors = %w[#6795d6 #e19593 #f2de97 #6d8e6a] %>
              <% memory.tag_list.first(2).each_with_index do |tag, i| %>
                <span class="tag">
                  <span class="tag-circle" style="background-color: <%= tag_colors[i % tag_colors.length] %>;"></span>
                  <p><%= tag %></p>
                </span>
              <% end %>
            </div>
          <% end %>
        <% end %>
        </div>
      </div>
      <div class="SliderControls RecentNotesSliderControls">
        <button class="SliderBtn SliderBtnPrev" id="recentNotesPrev" aria-label="Назад">
          <%= image_tag 'icons/SliderIcon.svg', class: 'SliderIcon' %>
        </button>
        <button class="SliderBtn SliderBtnNext" id="recentNotesNext" aria-label="Вперёд">
          <%= image_tag 'icons/SliderIcon.svg', class: 'SliderIcon SliderIconFlipped' %>
        </button>
      </div>
    </div>
  </div>
</section>

<section class="YourFamily">
  <div class="PageWrapper">
    <div class="YourFamilyHeader">
      <div class="RecentNotesHeading">
        <p class="Subtitle">Ваша семья</p>
        <h2>ЛЮДИ, С КОТОРЫМИ У ВАС ЕСТЬ СВЯЗИ</h2>
      </div>
      <div class="SliderControls">
        <button class="SliderBtn SliderBtnPrev" id="familyPrev" aria-label="Назад">
          <%= image_tag 'icons/SliderIcon.svg', class: 'SliderIcon' %>
        </button>
        <button class="SliderBtn SliderBtnNext" id="familyNext" aria-label="Вперёд">
          <%= image_tag 'icons/SliderIcon.svg', class: 'SliderIcon SliderIconFlipped' %>
        </button>
      </div>
    </div>
    <div class="YourFamilySliderWrapper">
      <div class="YourFamilyMembers" id="familySlider">
        <% @family_members.each do |member| %>
          <% profile = member.user&.profile %>
          <% card_tag  = profile ? :a : :div %>
          <% card_opts = profile ? { href: profile_path(profile), class: 'FamilyMemberContainer' } : { class: 'FamilyMemberContainer' } %>
          <%= content_tag(card_tag, **card_opts) do %>
            <p class="FamilyMemberName"><%= (profile&.name || member.name).split(' ').join('<br>').html_safe %></p>
            <% if profile&.birthday %>
              <p class="FamilyMemberBirthday"><%= l(profile.birthday, format: "%d %B, %Y") %></p>
            <% elsif member.respond_to?(:birthday) && member.birthday %>
              <p class="FamilyMemberBirthday"><%= l(member.birthday, format: "%d %B, %Y") %></p>
            <% else %>
              <p class="FamilyMemberBirthday"><%= member.relation&.capitalize %></p>
            <% end %>
            <% if profile&.avatar&.attached? %>
              <%= image_tag profile.avatar, class: 'FamilyMemberPhoto' %>
            <% else %>
              <%
                avatar_colors = %w[#6795d6 #e19593 #f2de97 #6d8e6a #a3b7a1 #ffb4b2]
                name_str = member.name.to_s
                color = avatar_colors[name_str.sum % avatar_colors.length]
                initials = name_str.split.first(2).map { |w| w[0]&.upcase }.join
              %>
              <div class="FamilyMemberPhoto FamilyMemberPhotoPlaceholder" style="background-color: <%= color %>;">
                <span class="ProfileInitials"><%= initials.presence || "?" %></span>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
    <div class="SliderControls YourFamilyMobileSliderControls">
      <button class="SliderBtn SliderBtnPrev" id="familyPrevMobile" aria-label="Назад">
        <%= image_tag 'icons/SliderIcon.svg', class: 'SliderIcon' %>
      </button>
      <button class="SliderBtn SliderBtnNext" id="familyNextMobile" aria-label="Вперёд">
        <%= image_tag 'icons/SliderIcon.svg', class: 'SliderIcon SliderIconFlipped' %>
      </button>
    </div>
  </div>
</section>

<script>
  (function() {
    function initSlider(sliderId, prevId, nextId, cardSelector) {
      const slider = document.getElementById(sliderId);
      const prev = document.getElementById(prevId);
      const next = document.getElementById(nextId);
      if (!slider || !prev || !next) return;

      const getStep = () => {
        const card = slider.querySelector(cardSelector);
        if (!card) return 340;
        return card.offsetWidth + 8;
      };

      prev.addEventListener('click', () => {
        slider.scrollBy({ left: -getStep(), behavior: 'smooth' });
      });
      next.addEventListener('click', () => {
        slider.scrollBy({ left: getStep(), behavior: 'smooth' });
      });

      const updateBtns = () => {
        prev.style.opacity = slider.scrollLeft <= 0 ? '0.3' : '1';
        next.style.opacity = slider.scrollLeft + slider.clientWidth >= slider.scrollWidth - 1 ? '0.3' : '1';
      };
      slider.addEventListener('scroll', updateBtns);
      updateBtns();
    }

    initSlider('familySlider', 'familyPrev', 'familyNext', '.FamilyMemberContainer');
    initSlider('familySlider', 'familyPrevMobile', 'familyNextMobile', '.FamilyMemberContainer');
    initSlider('recentNotesSlider', 'recentNotesPrev', 'recentNotesNext', '.ImageContainer');
  })();
</script>

