<section class="UserInfo">
    <div class="UserPhoto">
      <% if @profile&.avatar&.attached? %>
        <%= image_tag @profile.avatar, class: "ProfileImage" %>
      <% else %>
        <%
          avatar_colors = %w[#6795d6 #e19593 #f2de97 #6d8e6a #a3b7a1 #ffb4b2 ]
          name_str = @profile&.name.to_s
          color = avatar_colors[name_str.sum % avatar_colors.length]
          initials = name_str.split.first(2).map { |w| w[0]&.upcase }.join
        %>
        <div class="ProfilePlaceholder" style="background-color: <%= color %>;">
          <span class="ProfileInitials"><%= initials.presence || "?" %></span>
        </div>
      <% end %>
    </div>
    <div class="UserBio">
        <div class="UserBioName">
          <%= ((@profile&.name).presence || "Без имени").split(' ').join('<br>').html_safe %>
        </div>
        <div class="UserBioBirthday"><%= l(@profile.birthday, format: "%d %B, %Y") if @profile&.birthday %></div>
    </div>
    <div class="UserActionButtons">
        <% if can? :manage, @profile %>
        <div class="ProfileActions">
            <%= link_to edit_profile_path, class: 'EditButton' do %>
            Редактировать
            <%= image_tag 'icons/EditIcon.svg', class: 'EditIcon' %>
            <% end %>

            <div class="MoreMenu" data-controller="copy">
                <button type="button" class="MoreButton">
                    <span class="Dot"></span>
                    <span class="Dot"></span>
                    <span class="Dot"></span>
                </button>
                <div class="MoreMenuDropdown">
                    <button type="button" class="MoreMenuItem CopyFamilyCode" data-action="click->copy#copy" data-copy-text="<%= @profile.user.family&.invite_code %>">
                        Скопировать код семьи
                        <%= image_tag 'icons/CopyIcon.svg', class: 'CopyIcon' %>
                    </button>
                    <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: 'MoreMenuItem LogoutLink' do %>
                        Выйти
                        <%= image_tag 'icons/LogoutIcon.svg', class: 'LogoutIcon' %>
                    <% end %>
                </div>
                <div class="CopyToast" data-copy-target="toast">Код семьи скопирован</div>
            </div>
        </div>
        <% end %>
    </div>
</section>

<div class="TabsContainer">
  <!-- Скрытые переключатели -->
  <input type="radio" name="profile_tabs" id="tab1" checked class="tab-logic">
  <input type="radio" name="profile_tabs" id="tab2" class="tab-logic">

  <section class="ProfileNavBar">
    <label for="tab1" class="ProfileMemoriesButton">
      Воспоминания <span class="MemoriesCount"><%= @memories.count %></span>
    </label>
    <label for="tab2" class="ProfileSelectionsButton">
      Подборки <span class="MemoriesCount"><%= @collections.count %></span>
    </label>
  </section>

  <div class="ContentSection">
    <div id="memories-list" class="tab-panel">
      <div class="ProfileMemories">
        <%
          row_columns = 12
          pattern = [3, 3, 2, 2, 2, 2, 2, 3, 3, 2] # 3 = wide, 2 = narrow

          pattern_index = 0
          row_remaining = row_columns
          slots = [] # { width: }
          flexible_in_row = [] # indices of image cards placed in the current row

          next_pattern_width = -> { w = pattern[pattern_index % pattern.length]; pattern_index += 1; w }

          # Fits a card into the current grid row: use the desired width if it fits,
          # fall back to the alternate width (3<->2, image cards only). If we're
          # short by exactly 1 column, first try upgrading an earlier narrow image
          # card in this row to wide (it absorbs the leftover column and this card
          # starts a fresh row); if none is available, downgrade an earlier wide
          # image card to narrow instead (frees up room for this card to join the
          # row). Otherwise start a new row.
          assign_width = lambda do |desired, allow_alt|
            chosen = nil

            if desired <= row_remaining
              chosen = desired
            else
              alt = desired == 3 ? 2 : 3
              if allow_alt && alt <= row_remaining
                chosen = alt
              elsif row_remaining == desired - 1
                upgrade_index = flexible_in_row.reverse.find { |i| slots[i][:width] == 2 }
                if upgrade_index
                  slots[upgrade_index][:width] = 3
                else
                  downgrade_index = flexible_in_row.reverse.find { |i| slots[i][:width] == 3 }
                  if downgrade_index
                    slots[downgrade_index][:width] = 2
                    row_remaining += 1
                    chosen = desired
                  end
                end
              end
            end

            if chosen.nil?
              flexible_in_row.clear
              row_remaining = row_columns
              chosen = desired
            end

            row_remaining -= chosen
            slots << { width: chosen }
            flexible_in_row << (slots.length - 1) if allow_alt
            chosen
          end

          can_manage_profile = can?(:manage, @profile)

          if can_manage_profile && @memories.empty?
            slots << { width: row_columns }
          elsif can_manage_profile
            assign_width.call(next_pattern_width.call, true)
          end

          @memories.each do |memory|
            desired = next_pattern_width.call
            desired = 2 unless memory.image.present?
            assign_width.call(desired, memory.image.present?)
          end

          memory_widths = slots.last(@memories.size).map { |s| s[:width] }
        %>

        <% tag_colors = ["#6795d6", "#e19593", "#f2de97", "#6d8e6a"] %>

        <% if can_manage_profile %>
          <div class="AddMemorySpace MemoryItem <%= @memories.empty? ? 'CardFull' : '' %>" style="grid-column: span <%= slots.first[:width] %>;">
            <% if @memories.empty? %>
              <%= image_tag 'profile/EmptyFlower.svg', class: 'EmptyMemoriesDecor' %>
            <% end %>
            <h3 class="AddMemorySpaceText"><%= @memories.empty? ? 'У вас еще нет воспоминаний' : 'Добавить новое воспоминание' %></h3>
            <%= link_to new_memory_path, class: "AddMemoryButton" do %>
                Добавить <span class="PlusIcon"></span>
            <% end %>
          </div>
        <% end %>

        <% @memories.each_with_index do |memory, index| %>
          <div class="MemoryItem" style="grid-column: span <%= memory_widths[index] %>;">
            <div class="CardContent">
              <%= link_to memory_path(memory) do %>
                <% if memory.image.present? %>
                  <%= image_tag memory.image.preview.url, class: "MemoryImg" %>
                <% else %>
                  <div class="MemoryText">
                    <p><%= truncate(memory.body, length: 150) %></p>
                  </div>
                <% end %>
                <div class="tags">
                  <% memory.tags.each do |tag| %>
                    <% color = tag_colors[tag.id % tag_colors.length] %>
                    <span class="tag">
                      <span class="tag-circle" style="background-color: <%= color %>;"></span>
                      <%= tag.name %>
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
    <div id="collections-list" class="tab-panel">
      <div class="ProfileCollections">
        <% if can_manage_profile %>
          <%= link_to new_collection_path, class: "AddMemorySpace AddCollectionSpace #{'CardFull' if @collections.empty?}" do %>
            <% if @collections.empty? %>
              <%= image_tag 'profile/EmptyFlower.svg', class: 'EmptyMemoriesDecor' %>
            <% end %>
            <h3 class="AddMemorySpaceText"><%= @collections.empty? ? 'У вас еще нет подборок' : 'Добавить новую подборку' %></h3>
            <span class="AddMemoryButton">
              Добавить <span class="PlusIcon"></span>
            </span>
          <% end %>
        <% end %>

        <% tag_colors = ["#6795d6", "#e19593", "#f2de97", "#6d8e6a"] %>

        <% @collections.each do |collection| %>
          <%= link_to collection_path(collection), class: "CollectionCard" do %>
            <%= image_tag "profile/collections/#{collection.decor_icon}", class: "CollectionCardDecor" %>
            <div class="CollectionCardImageWrap">
              <% cover_memory = collection.memories.first %>
              <% if cover_memory&.image.present? %>
                <%= image_tag cover_memory.image.preview.url, class: "CollectionCardImg" %>
              <% else %>
                <div class="CollectionCardImg CollectionCardImgPlaceholder"></div>
              <% end %>
            </div>
            <div class="CollectionCardFooter">
              <div class="CollectionCardInfo">
                <h3 class="CollectionCardTitle"><%= collection.title %></h3>
                <div class="tags">
                  <% collection.category_list.each do |tag| %>
                    <span class="tag">
                      <span class="tag-circle" style="background-color: <%= tag_colors[tag.sum % tag_colors.length] %>;"></span>
                      <%= tag %>
                    </span>
                  <% end %>
                </div>
              </div>
              <p class="CollectionCardDate"><%= l(collection.date, format: "%-d %B, %Y") if collection.date %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>


